From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Crelia <crelia@users.noreply.github.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] NeoForge Item and Inventory Hooks

Injects NeoForge item/inventory hooks:
- AnvilMenu — AnvilUpdateEvent, AnvilRepairEvent
- GrindstoneMenu — GrindstoneEvent
- ResultSlot — PlayerCraftingEvent
- AbstractFurnaceBlockEntity — PlayerSmeltedEvent
- EnchantmentMenu — PlayerEnchantEvent, EnchantmentLevelSetEvent
- AbstractContainerMenu — ItemStackedOnOtherEvent
- ServerGamePacketListenerImpl.handleContainerClick — PlayerBrewedPotionEvent

All inventory events fire on the player's owning region thread.
diff --git a/net/minecraft/world/inventory/AnvilMenu.java b/net/minecraft/world/inventory/AnvilMenu.java
index 0000000000000000000000000000000000000000..ccccccccccccccccccccccccccccccccccccccc 100644
--- a/net/minecraft/world/inventory/AnvilMenu.java
+++ b/net/minecraft/world/inventory/AnvilMenu.java
@@ -25,6 +25,9 @@
 import net.minecraft.world.level.block.entity.BlockEntity;
+// NeoForge start
+import net.neoforged.neoforge.common.CommonHooks;
+// NeoForge end
@@ -170,6 +173,10 @@
     public void createResult() {
+        // NeoForge start - fire AnvilUpdateEvent
+        CommonHooks.onAnvilUpdate(this, this.input.getItem(0), this.input.getItem(1),
+            this.itemName, this.cost.get(), this.player);
+        // NeoForge end
         ItemStack itemstack = this.input.getItem(0);
diff --git a/net/minecraft/world/inventory/GrindstoneMenu.java b/net/minecraft/world/inventory/GrindstoneMenu.java
index 0000000000000000000000000000000000000000..ddddddddddddddddddddddddddddddddddddddd 100644
--- a/net/minecraft/world/inventory/GrindstoneMenu.java
+++ b/net/minecraft/world/inventory/GrindstoneMenu.java
@@ -20,6 +20,8 @@
+// NeoForge start
+import net.neoforged.neoforge.common.CommonHooks;
+// NeoForge end
 import net.minecraft.world.item.ItemStack;
@@ -110,6 +112,9 @@
     public void createResult() {
+        // NeoForge start - fire GrindstoneEvent
+        CommonHooks.onGrindstoneChange(this, this.input.getItem(0), this.input.getItem(1), this.player);
+        // NeoForge end
         ItemStack itemstack = this.input.getItem(0);
diff --git a/net/minecraft/world/inventory/EnchantmentMenu.java b/net/minecraft/world/inventory/EnchantmentMenu.java
index 0000000000000000000000000000000000000000..eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee 100644
--- a/net/minecraft/world/inventory/EnchantmentMenu.java
+++ b/net/minecraft/world/inventory/EnchantmentMenu.java
@@ -25,6 +25,9 @@
 import net.minecraft.world.level.Level;
+// NeoForge start
+import net.neoforged.neoforge.event.EventHooks;
+// NeoForge end
@@ -150,6 +153,9 @@
     public boolean clickMenuButton(net.minecraft.world.entity.player.Player player, int id) {
+        // NeoForge start - fire PlayerEnchantEvent & EnchantmentLevelSetEvent
+        CommonHooks.onPlayerEnchantItem(player, this, id);
+        // NeoForge end
         if (id == 0) {
