@@ -1153,6 +1159,7 @@ public abstract class MinecraftServer extends ReentrantBlockableEventLoop<TickTa
     }
     public void stopPart2() {
         // Folia end - region threading
+        ServerLifecycleHooks.handleServerStopped(this); // NeoForge - fire ServerStoppedEvent
         this.resources.close();
 
         try {
@@ -1206,6 +1213,7 @@ public abstract class MinecraftServer extends ReentrantBlockableEventLoop<TickTa
         // Paper end
         this.running = false;
         this.stopServer(); // Folia - region threading
+        ServerLifecycleHooks.handleServerStopping(this); // NeoForge - fire ServerStoppingEvent (safeShutdown path)
         if (waitForShutdown) {
             try {
                 this.serverThread.join();
@@ -1288,11 +1296,14 @@ public abstract class MinecraftServer extends ReentrantBlockableEventLoop<TickTa
             // Folia start - region threading
             if (true) {
                 io.papermc.paper.threadedregions.RegionizedServer.getInstance().init(); // Folia - region threading - only after loading worlds
+                ServerLifecycleHooks.handleServerAboutToStart(this); // NeoForge - fire ServerAboutToStartEvent
