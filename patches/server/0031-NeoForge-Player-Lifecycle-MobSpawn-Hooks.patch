From: Crelia <crelia@users.noreply.github.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] NeoForge Player Lifecycle and Mob Spawn Hooks

Injects NeoForge hooks for player lifecycle and mob spawning:
- PlayerList: PlayerLoggedOutEvent, PlayerRespawnEvent, PlayerChangedDimensionEvent
- PlayerList.load: PlayerLoadingEvent
- PlayerList.save: PlayerSavingEvent
- ServerPlayer.changeDimension: firePlayerChangedDimensionEvent
- ServerPlayer.startSleepInBed: canPlayerStartSleeping
- Player.stopSleeping: onPlayerWakeup
- SpawnPlacements.checkSpawnRules: checkSpawnPlacements
- NaturalSpawner: checkSpawnPosition, getMaxSpawnClusterSize
- Animal.tame: onAnimalTame
- Slime.remove: onMobSplit
- Zombie/Enderman: canEntityGrief, canEntityDestroy

Spawn hooks fire on the world's region thread for the spawn position.
diff --git a/net/minecraft/server/players/PlayerList.java b/net/minecraft/server/players/PlayerList.java
index aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa..fffffffffffffffffffffffffffffffffffffffff 100644
--- a/net/minecraft/server/players/PlayerList.java
+++ b/net/minecraft/server/players/PlayerList.java
@@ -420,6 +420,9 @@
     public void remove(net.minecraft.server.level.ServerPlayer player) {
+        // NeoForge start - fire PlayerLoggedOutEvent
+        EventHooks.firePlayerLoggedOut(player);
+        // NeoForge end
         // Paper start
@@ -500,6 +503,9 @@
     public net.minecraft.server.level.ServerPlayer respawn(
+        // NeoForge start - fire PlayerRespawnEvent
+        EventHooks.firePlayerRespawnEvent(player, keepEverything);
+        // NeoForge end
diff --git a/net/minecraft/server/level/ServerPlayer.java b/net/minecraft/server/level/ServerPlayer.java
index 0000000000000000000000000000000000000000..gggggggggggggggggggggggggggggggggggggg 100644
--- a/net/minecraft/server/level/ServerPlayer.java
+++ b/net/minecraft/server/level/ServerPlayer.java
@@ -35,6 +35,9 @@
 import net.minecraft.server.players.PlayerList;
+// NeoForge start
+import net.neoforged.neoforge.event.EventHooks;
+import net.neoforged.neoforge.common.CommonHooks;
+// NeoForge end
@@ -750,6 +753,9 @@
     public Entity changeDimension(net.minecraft.resources.ResourceKey<Level> dimension) {
+        // NeoForge start - fire PlayerChangedDimensionEvent
+        EventHooks.firePlayerChangedDimensionEvent(this, this.level().dimension(), dimension);
+        // NeoForge end
@@ -1200,6 +1206,9 @@
     public Either<Player.BedSleepingProblem, Unit> startSleepInBed(BlockPos pos) {
+        // NeoForge start - fire PlayerSleepInBedEvent
+        if (!EventHooks.canPlayerStartSleeping(this, pos)) return Either.left(Player.BedSleepingProblem.OTHER_PROBLEM);
+        // NeoForge end
diff --git a/net/minecraft/world/entity/SpawnPlacements.java b/net/minecraft/world/entity/SpawnPlacements.java
index 0000000000000000000000000000000000000000..hhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhh 100644
--- a/net/minecraft/world/entity/SpawnPlacements.java
+++ b/net/minecraft/world/entity/SpawnPlacements.java
@@ -10,6 +10,9 @@
 import net.minecraft.world.phys.Vec3;
+// NeoForge start
+import net.neoforged.neoforge.event.EventHooks;
+// NeoForge end
@@ -55,6 +58,9 @@
     public static boolean checkSpawnRules(EntityType<?> type, ServerLevelAccessor level, SpawnReason spawnReason, BlockPos pos, RandomSource random) {
+        // NeoForge start - fire CheckSpawn event
+        if (!EventHooks.checkSpawnPlacements(type, level, spawnReason, pos, random)) return false;
+        // NeoForge end
diff --git a/net/minecraft/world/level/NaturalSpawner.java b/net/minecraft/world/level/NaturalSpawner.java
index 0000000000000000000000000000000000000000..iiiiiiiiiiiiiiiiiiiiiiiiiiiiiiiiiiiiii 100644
--- a/net/minecraft/world/level/NaturalSpawner.java
+++ b/net/minecraft/world/level/NaturalSpawner.java
@@ -180,6 +180,9 @@
     public static void spawnCategoryForPosition(ServerLevel level, MobCategory category, BlockPos pos, RandomSource random) {
+        // NeoForge start - fire CheckSpawn event
+        if (!EventHooks.checkSpawnPosition(type, level, SpawnReason.NATURAL, pos, random)) continue;
+        // NeoForge end
