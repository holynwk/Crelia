+// NeoForge start - entity tick events
+import net.neoforged.neoforge.event.EventHooks;
+import net.neoforged.neoforge.event.tick.EntityTickEvent;
+// NeoForge end
 
 // CraftBukkit start
 import java.util.ArrayList;
@@ -3149,6 +3153,8 @@ public abstract class LivingEntity extends Entity implements Attackable {
     @Override
     public void tick() {
         super.tick();
+        EntityTickEvent.Pre tickPre = EventHooks.fireEntityTickPre(this); // NeoForge - fire EntityTickEvent.Pre
+        if (tickPre.isCanceled()) return; // NeoForge - honor cancellation
         this.updatingUsingItem();
         this.updateSwimAmount();
         if (!this.level().isClientSide) {
@@ -3257,6 +3263,7 @@ public abstract class LivingEntity extends Entity implements Attackable {
             this.appliedScale = f4;
             this.refreshDimensions();
         }
+        EventHooks.fireEntityTickPost(this); // NeoForge - fire EntityTickEvent.Post
 
     }
 
