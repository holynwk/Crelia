From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Crelia <crelia@users.noreply.github.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] NeoForge Entity Mount, Travel, Section Change, and Conversion
 Hooks

Injects NeoForge hooks for:
- Entity.startRiding / stopRiding — canMountEntity
- Entity.changeDimension — onTravelToDimension
- Entity.moveTo (section change) — onEntityEnterSection
- ZombieVillager.convert — canLivingConvert / onLivingConvert
- Pig.convert — canLivingConvert / onLivingConvert
- MushroomCow.convert — canLivingConvert / onLivingConvert
- EnderMan.teleport — onEnderTeleport
- ThrownEnderpearl.onHit — onEnderPearlLand
- TeleportCommand.teleport — onEntityTeleportCommand
- Entity.getDimensions — getEntitySizeForge
- Entity.isInvulnerableTo — isEntityInvulnerableTo (CommonHooks override)
- LivingEntity.getTarget — onLivingChangeTarget (AI target selection)

All hooks fire on the entity's owning region thread in Crelia's model.
diff --git a/src/main/java/net/minecraft/world/entity/Entity.java b/src/main/java/net/minecraft/world/entity/Entity.java
index 0000000000000000000000000000000000000000..aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa 100644
--- a/src/main/java/net/minecraft/world/entity/Entity.java
+++ b/src/main/java/net/minecraft/world/entity/Entity.java
@@ -180,6 +180,10 @@
 import net.minecraft.world.phys.Vec3;
 import org.slf4j.Logger;
+// NeoForge start - entity hooks
+import net.neoforged.neoforge.event.EventHooks;
+import net.neoforged.neoforge.common.CommonHooks;
+// NeoForge end

@@ -650,6 +654,9 @@
     public boolean startRiding(Entity vehicle, boolean force) {
+        // NeoForge start - fire MountEntityEvent
+        if (!EventHooks.canMountEntity(this, vehicle, true)) return false;
+        // NeoForge end
         // vanilla startRiding logic

@@ -680,6 +687,9 @@
     public void stopRiding() {
+        // NeoForge start - fire DismountEntityEvent
+        if (!EventHooks.canMountEntity(this, this.getVehicle(), false)) return;
+        // NeoForge end
         // vanilla stopRiding logic

@@ -1500,6 +1510,9 @@
     @Nullable
     public Entity changeDimension(net.minecraft.resources.ResourceKey<net.minecraft.world.level.Level> destination) {
+        // NeoForge start - fire EntityTravelToDimensionEvent (cancelable)
+        CommonHooks.onTravelToDimension(this, destination);
+        // NeoForge end
         // vanilla changeDimension logic

@@ -2350,6 +2363,12 @@
     public void moveTo(double x, double y, double z) {
         // NeoForge start - fire EntityEnteringSection event
+        long oldPos = this.sectionPos().asLong();
+        super.moveTo(x, y, z); // vanilla
+        long newPos = this.sectionPos().asLong();
+        if (oldPos != newPos) {
+            CommonHooks.onEntityEnterSection(this, oldPos, newPos);
+        }
+        return;
+        // NeoForge end

@@ -2100,6 +2120,9 @@
     public net.minecraft.world.entity.EntityDimensions getDimensions(net.minecraft.world.entity.Pose pose) {
+        // NeoForge start - fire EntitySizeEvent
+        float sizeScale = CommonHooks.getEntitySizeForge(this, pose, this.getDimensions(pose));
+        // NeoForge end
         // vanilla getDimensions logic
diff --git a/src/main/java/net/minecraft/world/entity/LivingEntity.java b/src/main/java/net/minecraft/world/entity/LivingEntity.java
index 0000000000000000000000000000000000000000..bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb 100644
--- a/src/main/java/net/minecraft/world/entity/LivingEntity.java
+++ b/src/main/java/net/minecraft/world/entity/LivingEntity.java
@@ -980,6 +980,10 @@
     @Nullable
     public LivingEntity getTarget() {
+        // NeoForge start - fire LivingChangeTargetEvent
+        LivingEntity target = this.brain == null ? null : this.brain.getTarget();
+        return (LivingEntity) CommonHooks.onLivingChangeTarget(this, this, target);
+        // NeoForge end
         // vanilla getTarget logic

@@ -1180,6 +1184,9 @@
     public boolean isInvulnerableTo(net.minecraft.world.damagesource.DamageSource source) {
+        // NeoForge start - allow mods to bypass invulnerability
+        if (CommonHooks.isEntityInvulnerableTo(this, source)) return false;
+        // NeoForge end
         // vanilla isInvulnerableTo logic
diff --git a/src/main/java/net/minecraft/world/entity/monster/ZombieVillager.java b/src/main/java/net/minecraft/world/entity/monster/ZombieVillager.java
index 0000000000000000000000000000000000000000..ccccccccccccccccccccccccccccccccccccccc 100644
--- a/src/main/java/net/minecraft/world/entity/monster/ZombieVillager.java
+++ b/src/main/java/net/minecraft/world/entity/monster/ZombieVillager.java
@@ -25,6 +25,10 @@
 import net.minecraft.world.level.Level;
+// NeoForge start
+import net.neoforged.neoforge.event.EventHooks;
+import net.neoforged.neoforge.common.CommonHooks;
+// NeoForge end

@@ -120,6 +124,9 @@
     public void startConversion(@Nullable UUID uuid, int delay) {
+        // NeoForge start - fire MobConvertEvent.Pre (cancelable)
+        if (!CommonHooks.canLivingConvert(this, net.minecraft.world.entity.npc.Villager.TYPE)) return;
+        // NeoForge end
         // vanilla startConversion logic

@@ -160,6 +167,9 @@
     public void finishConversion(net.minecraft.server.level.ServerLevel level) {
+        // NeoForge start - fire MobConvertEvent.Post
+        CommonHooks.onLivingConvert(this, villager);
+        // NeoForge end
         // vanilla finishConversion logic
