@@ -300,6 +307,9 @@
     public boolean isLookingAtMe(net.minecraft.world.entity.player.Player player) {
+        // NeoForge start - allow mods to suppress enderman anger
+        if (CommonHooks.shouldSuppressEnderManAnger(this, player)) return false;
+        // NeoForge end
         // vanilla isLookingAtMe logic
