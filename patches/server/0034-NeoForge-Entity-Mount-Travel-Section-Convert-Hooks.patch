@@ -120,6 +123,9 @@
     private static int teleport(net.minecraft.commands.CommandSourceStack source, net.minecraft.world.entity.Entity target, net.minecraft.world.phys.Vec3 location, net.minecraft.world.phys.Vec3 rotation, TeleportCommand.LookAt facing, boolean preserveMotion) {
