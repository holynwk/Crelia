@@ -80,6 +84,9 @@
     public void onLightningStrike(net.minecraft.server.level.ServerLevel level, net.minecraft.world.entity.LightningBolt lightning) {
+        // NeoForge start - fire MobConvertEvent.Pre
+        if (!CommonHooks.canLivingConvert(this, net.minecraft.world.entity.monster.ZombifiedPiglin.TYPE)) return;
