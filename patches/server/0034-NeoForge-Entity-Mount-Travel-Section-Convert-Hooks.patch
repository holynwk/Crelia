+import net.neoforged.neoforge.event.EventHooks;
+// NeoForge end
@@ -60,2 +63,5 @@
     protected void onHit(net.minecraft.world.phys.HitResult result) {
+        // NeoForge start - fire EnderPearlLandEvent
