     public boolean hasCorrectToolForDrops(net.minecraft.world.level.block.state.BlockState state) {
+        // NeoForge start - fire HarvestCheck event
+        boolean canHarvest = /* vanilla check */;
+        EventHooks.doPlayerHarvestCheck(this, state, canHarvest);
+        // NeoForge end
         // vanilla hasCorrectToolForDrops logic

@@ -610,6 +614,10 @@
     public float getDigSpeed(net.minecraft.world.level.block.state.BlockState state, @Nullable net.minecraft.core.BlockPos pos) {
+        // NeoForge start - fire BreakSpeed event
+        float speed = /* vanilla speed calculation */;
+        speed = EventHooks.getBreakSpeed(this, state, speed, pos);
+        // NeoForge end
         // vanilla getDigSpeed logic
diff --git a/src/main/java/net/minecraft/server/network/ServerGamePacketListenerImpl.java b/src/main/java/net/minecraft/server/network/ServerGamePacketListenerImpl.java
index 0000000000000000000000000000000000000000..3333333333333333333333333333333333333333 100644
--- a/src/main/java/net/minecraft/server/network/ServerGamePacketListenerImpl.java
+++ b/src/main/java/net/minecraft/server/network/ServerGamePacketListenerImpl.java
@@ -700,6 +700,10 @@
     public void handlePlayerAction(net.minecraft.network.protocol.game.ServerboundPlayerActionPacket packet) {
         // When action is START_DESTROY_BLOCK:
+        // NeoForge start - fire BreakEvent
+        net.minecraft.core.BlockPos pos = packet.getPos();
+        CommonHooks.fireBlockBreak(this.player.level(), pos, this.player.level().getBlockState(pos), this.player, true);
+        // NeoForge end
         // vanilla handlePlayerAction logic

@@ -1200,6 +1204,9 @@
     public void handleContainerClick(net.minecraft.network.protocol.game.ServerboundContainerClickPacket packet) {
+        // NeoForge start - fire PlayerBrewedPotionEvent (for brewing stand result slot)
+        EventHooks.onPlayerBrewedPotion(this.player, craftedStack);
+        // NeoForge end
         // vanilla handleContainerClick logic
