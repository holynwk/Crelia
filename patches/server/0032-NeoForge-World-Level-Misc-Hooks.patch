From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Crelia <crelia@users.noreply.github.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] NeoForge World Level and Misc Hooks

Injects remaining NeoForge hooks:
- ServerLevel.advanceDayTime — SleepFinishedTimeEvent
- GameRules.set — GameRuleChangedEvent
- Player.awardStat — StatAwardEvent
- PlayerAdvancements.award — AdvancementEarnedEvent
- Level.gameEvent — VanillaGameEvent filter
- Commands.registerAll — CommandRegisterEvent
- Entity.thunderHit — onEntityStruckByLightning
- LivingEntity.dropExperience — getExperienceDrop
- BlockEntityTypeAddBlocksEvent integration
- ServerResources — onResourceReload

These hooks cover the remaining NeoForge event integration points.
diff --git a/net/minecraft/world/level/GameRules.java b/net/minecraft/world/level/GameRules.java
index 0000000000000000000000000000000000000000..jjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjjj 100644
--- a/net/minecraft/world/level/GameRules.java
+++ b/net/minecraft/world/level/GameRules.java
@@ -120,6 +120,9 @@
     public void set(GameRules.Key<?> key, String value) {
+        // NeoForge start - fire GameRuleChangedEvent
+        EventHooks.onGameRuleChanged(this, key, key.type, this.get(key));
+        // NeoForge end
diff --git a/net/minecraft/world/entity/Entity.java b/net/minecraft/world/entity/Entity.java
index 0000000000000000000000000000000000000000..kkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkkk 100644
--- a/net/minecraft/world/entity/Entity.java
+++ b/net/minecraft/world/entity/Entity.java
@@ -2800,6 +2800,9 @@
     public void thunderHit(ServerLevel level, LightningBolt lightning) {
+        // NeoForge start - fire EntityStruckByLightningEvent
+        EventHooks.onEntityStruckByLightning(this, lightning);
+        // NeoForge end
         this.setRemainingFireTicks(this.remainingFireTicks + 1);
diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index 5555555555555555555555555555555555555555..llllllllllllllllllllllllllllllllllllll 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -1960,6 +1960,9 @@
     public void dropExperience(ServerLevel level) {
+        // NeoForge start - modify experience drops
+        int xp = EventHooks.getExperienceDrop(this, this.lastHurtByPlayer, this.xpReward);
+        // NeoForge end
diff --git a/net/minecraft/commands/Commands.java b/net/minecraft/commands/Commands.java
index 0000000000000000000000000000000000000000..mmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmm 100644
--- a/net/minecraft/commands/Commands.java
+++ b/net/minecraft/commands/Commands.java
@@ -200,6 +200,9 @@
     private void registerAll(boolean dedicated) {
+        // NeoForge start - fire RegisterCommandsEvent
+        EventHooks.onCommandRegister(this, dedicated);
+        // NeoForge end
