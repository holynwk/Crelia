From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Crelia <crelia@users.noreply.github.com>
Date: Mon, 1 Jan 2024 00:00:00 +0000
Subject: [PATCH] NeoForge LivingEntity Damage Hooks

Injects NeoForge damage-system hooks into LivingEntity:
- onEntityIncomingDamage in hurt() — LivingDamageEvent.Pre
- onLivingDamagePost in actuallyHurt() — LivingDamageEvent.Post
- onLivingKnockBack in knockback()
- onArmorHurt in hurtArmor()
- onLivingUseTotem in checkTotemDeathProtection()
- onEffectRemoved in removeEffect()
- onLivingDrops in dropAllDeathLoot()

These are the core of NeoForge's damage modification system.
In Crelia, all these hooks run on the entity's owning region thread,
ensuring thread safety without additional synchronization.
diff --git a/net/minecraft/world/entity/LivingEntity.java b/net/minecraft/world/entity/LivingEntity.java
index 1111111111111111111111111111111111111111..5555555555555555555555555555555555555555 100644
--- a/net/minecraft/world/entity/LivingEntity.java
+++ b/net/minecraft/world/entity/LivingEntity.java
@@ -1310,6 +1310,10 @@
     public boolean hurt(DamageSource source, float amount) {
         // Paper start
         if (!this.level().paperConfig().entities.mobExplosionDamage.enabled && source.is(net.minecraft.world.damagesource.DamageTypes.BAD_RESPAWN_POINT)) return false; // Folia - region threading
+        // NeoForge start - fire LivingDamageEvent.Pre
+        if (CommonHooks.onEntityIncomingDamage(this, source, amount)) return false;
+        // NeoForge end
 
         if (this.isInvulnerableTo(source)) {
@@ -1330,6 +1334,9 @@
     public boolean isInvulnerableTo(DamageSource source) {
+        // NeoForge start - allow mods to bypass invulnerability
+        if (CommonHooks.isEntityInvulnerableTo(this, source)) return false;
+        // NeoForge end
         if (this.isRemoved()) return true; // CraftBukkit - SPIGOT-7625
@@ -1515,6 +1522,9 @@
     public void knockback(double strength, double ratioX, double ratioZ) {
+        // NeoForge start - fire LivingKnockBackEvent
+        CommonHooks.onLivingKnockBack(this, null, (float)strength, ratioX, ratioZ);
+        // NeoForge end
         if (this.isSuppressingBounce()) {
@@ -1650,6 +1660,9 @@
     protected void hurtArmor(DamageSource source, float damage) {
+        // NeoForge start - fire LivingShieldBlockEvent
+        CommonHooks.onArmorHurt(this, source, damage);
+        // NeoForge end
@@ -1720,6 +1733,10 @@
     public boolean checkTotemDeathProtection(DamageSource source) {
+        // NeoForge start - fire LivingEntityUseTotemEvent
+        ItemStack totem = null;
+        if (CommonHooks.onLivingUseTotem(this, source, totem)) return false;
+        // NeoForge end
         if (source.is(DamageTypeTags.BYPASSES_COOLDOWN)) {
@@ -1830,6 +1847,9 @@
     protected void actuallyHurt(DamageSource source, float amount) {
+        // NeoForge start - fire LivingDamageEvent.Post
+        amount = CommonHooks.onLivingDamagePost(this, source, amount, amount);
+        // NeoForge end
         if (!this.isDamageTicked()) {
@@ -1230,6 +1242,9 @@
     public boolean removeEffect(MobEffect effect) {
+        // NeoForge start - fire MobEffectRemoveEvent
+        if (EventHooks.onEffectRemoved(this, effect, EntityRemoveReason.REMOVED)) return false;
+        // NeoForge end
@@ -1900,6 +1915,9 @@
     public void dropAllDeathLoot(DamageSource source) {
+        // NeoForge start - fire LivingDropsEvent
+        CommonHooks.onLivingDrops(this, source, this.drops, recentlyHit > 0, lootingLevel);
+        // NeoForge end
